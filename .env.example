# Coturn STUN/TURN Server Configuration
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=development
PORT=5002
SOCKET_URL=http://localhost:5002

# Coturn TURN Server Configuration
TURN_SERVER_URL=turn:your-domain.com:3478
TURN_SECRET_KEY=your-super-secret-key-change-this-in-production
TURN_REALM=unitalks
TURN_CREDENTIAL_TTL=3600
TURN_PUBLIC_IP=your-public-ip-address

# STUN Server Configuration (fallback)
STUN_SERVER_URL=stun:stun.l.google.com:19302

# SSL/TLS Configuration (for TURN over TLS)
TURN_TLS_CERT_PATH=/path/to/your/cert.pem
TURN_TLS_KEY_PATH=/path/to/your/private.key

# Security Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
FORCE_HTTPS=false

# Redis Configuration (optional, for distributed deployments)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Support Email Configuration
SUPPORT_TO=support@your-domain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-domain.com

# Rate Limiting
SUPPORT_RATE_LIMIT_WINDOW_MS=900000
SUPPORT_RATE_LIMIT_MAX_REQUESTS=20

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/turnserver.log
